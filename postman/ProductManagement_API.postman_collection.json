            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Correlation-Id", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Basic Tee\",\n  \"description\": \"A comfortable everyday t-shirt.\",\n  \"basePrice\": 29.99,\n  \"categoryId\": \"{{category_id}}\",\n  \"status\": 1,\n  \"initialVariants\": [\n    {\n      \"sku\": \"BASIC-TEE-S-WHT\",\n      \"price\": null,\n      \"stock\": 50,\n      \"attributes\": { \"size\": \"S\", \"color\": \"White\" }\n    },\n    {\n      \"sku\": \"BASIC-TEE-M-WHT\",\n      \"price\": null,\n      \"stock\": 100,\n      \"attributes\": { \"size\": \"M\", \"color\": \"White\" }\n    },\n    {\n      \"sku\": \"BASIC-TEE-L-BLK\",\n      \"price\": 27.99,\n      \"stock\": 75,\n      \"attributes\": { \"size\": \"L\", \"color\": \"Black\" }\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
