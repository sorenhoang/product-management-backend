      "name": "Categories",
      "item": [
        {
          "name": "POST Create Category (top-level)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Response success is true\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "});",
                  "pm.test(\"category_id is captured\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.data.id).to.be.a('string');",
                  "    pm.environment.set(\"category_id\", body.data.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Correlation-Id", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Clothing\",\n  \"parentId\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v{{version}}/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "v{{version}}", "categories"]
