        {
          "name": "POST Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test(\"Response success is true\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.success).to.be.true;",
                  "});",
                  "pm.test(\"Product has 3 variants\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.data.variants.length).to.equal(3);",
                  "});",
                  "pm.test(\"Message is Product created successfully\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.message).to.equal(\"Product created successfully.\");",
                  "});",
                  "pm.test(\"product_id and variant_id are captured\", function () {",
                  "    var body = pm.response.json();",
                  "    pm.expect(body.data.id).to.be.a('string');",
                  "    pm.environment.set(\"product_id\", body.data.id);",
                  "    pm.environment.set(\"variant_id\", body.data.variants[0].id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
